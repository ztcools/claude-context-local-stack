# =============================================================================
# claude-context 一体化部署配置模板
# 用法: cp .env.example .env  然后按实际情况修改。
# 注意: .env 含密钥,已被 .gitignore 忽略,请勿提交。
# =============================================================================

# ---- 通用 -------------------------------------------------------------------
# 容器名 / 网络名前缀
PROJECT_PREFIX=claude
# Milvus 数据持久化根目录(下含 etcd / minio / milvus)。默认在部署目录下 ./data;
# 若要复用已有 Milvus 数据,指向其 volumes 目录的绝对路径即可。
DATA_DIR=./data

# ---- MinIO(Milvus 对象存储)------------------------------------------------
# 复用现有 milvus 数据时,凭据必须与原部署一致(原为 minioadmin/minioadmin)。
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- Milvus -----------------------------------------------------------------
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091

# ---- Ollama(向量化推理)----------------------------------------------------
OLLAMA_PORT=11435
# Ollama 模型数据目录。默认 ./data/ollama;复用已有模型时指向其数据目录的绝对路径。
OLLAMA_DATA=./data/ollama
EMBED_MODEL=nomic-embed-text
EMBED_DIMENSION=768
OLLAMA_GPU_COUNT=all
OLLAMA_NUM_GPUS=4
OLLAMA_NUM_PARALLEL=8
OLLAMA_PARALLEL_REQUESTS=32
OLLAMA_MAX_BATCH_SIZE=1024
OLLAMA_CPU_THREADS=16

# ---- git-index(定时索引服务)----------------------------------------------
# 管理 API + 前端“GitLab 仓库管理”页使用的宿主端口(浏览器直连)。
GIT_INDEX_PORT=8795
# git-index 工作目录(仓库克隆 + 配置文件持久化)。
GIT_INDEX_DATA=./data/git-index
# 每日定时拉取的小时(0-23),也可在网页里改。
GIT_INDEX_DAILY_HOUR=3
# 内网 GitLab 若为自签证书,设为 true 跳过 TLS 校验。
GIT_SSL_NO_VERIFY=false
# 以该 uid:gid 运行 git-index,避免克隆产物出现 root 属主文件(服务器上为 1015:1015)。
GIT_INDEX_UID=1015
GIT_INDEX_GID=1015

# ---- PhiGent(Web 控制台)---------------------------------------------------
PHIGENT_PORT=18000
# phigent 服务端连接 Milvus(同 compose 网络用容器名)。
MILVUS_URL=standalone:19530
