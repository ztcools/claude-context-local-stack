# =============================================================================
# claude-context 部署配置模板
# 用法: cp .env.example .env  然后按本公司实际情况修改下方各项。
# 注意: .env 含密钥,已被 .gitignore 忽略,请勿提交到仓库。
# =============================================================================

# ---- 通用 -------------------------------------------------------------------
# 容器名 / 网络名前缀,多套环境共存时改成不同值(如 teamA、teamB)
PROJECT_PREFIX=claude
# 数据持久化根目录(etcd / minio / milvus 数据都放这下面)。建议用绝对路径。
DATA_DIR=./data

# ---- MinIO(Milvus 的对象存储)---------------------------------------------
# 【必改】生产环境务必改成强口令,不要用默认值。
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- Milvus -----------------------------------------------------------------
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091

# ---- Attu(Milvus Web 控制台)----------------------------------------------
ATTU_PORT=18000
# 同机部署保持默认即可;连接外部 Milvus 时改为  宿主机IP:19530
MILVUS_URL=standalone:19530

# ---- Ollama(向量化推理)----------------------------------------------------
OLLAMA_PORT=11435
OLLAMA_DATA=./data/ollama
# 嵌入模型,claude-context 默认使用 nomic-embed-text
EMBED_MODEL=nomic-embed-text
# GPU 数量:全部用 all,或填具体数字如 1、2;纯 CPU 见 README(需删 compose 的 deploy 段)
OLLAMA_GPU_COUNT=all
OLLAMA_NUM_GPUS=1
# 性能调优(按显卡数量与显存酌情调整)
OLLAMA_NUM_PARALLEL=8
OLLAMA_PARALLEL_REQUESTS=32
OLLAMA_MAX_BATCH_SIZE=1024
OLLAMA_CPU_THREADS=16
